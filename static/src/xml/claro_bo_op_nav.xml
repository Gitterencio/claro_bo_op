<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="claro_bo_op.status_form_btn">
        <div class="o_mail_systray_item">
            <a id="bo_status_green_on" 
               style="color:#65DE3C; cursor: pointer;" 
               title="Desactivar estado" 
               href="#" 
               role="button">
                <i class="fa fa-user" role="img" aria-label="CHEK"/>
            </a>
            <a id="bo_status_red_off" 
               style="color:#DE8D3C; cursor: pointer;" 
               title="Activar estado" 
               href="#" 
               role="button">
                <i class="fa fa-user-times" role="img" aria-label="CHEK"/>
            </a>
        </div>
    </t>

<t t-name="claro_bo_op.status_record_list">
        <div class="o_mail_systray_item dropdown">
            <a id="show-list" style="color:#ffffff;" class="dropdown-toggle o-no-caret" data-toggle="dropdown" data-display="static" aria-expanded="false" title="Ventas en Proceso" href="#" role="button">
                <i id="show-list-ico" class="fa fa-list-alt" role="img" aria-label="QR"/>
            </a>

            <ul class="o_mail_navbar_dropdown dropdown-menu dropdown-menu-right" role="menu">
                <li class="o_mail_navbar_dropdown_top">
                    <div class="container" style="padding-top: 2px;">
                        <form class="form_qr" name="f_qr">
                            <div class="form-group">
                                <div class="col-100">
                                    <center>
                                        <h4>Ventas en Proceso \u00A0<i id="show-list-ul" style="color:#DE8D3C; cursor: pointer;" class="fa fa-refresh" role="img" aria-label="QR"/></h4>
                                        <hr style="border: none; border-bottom: 1px solid gainsboro;"/>
                                    </center>
                                </div>
                            </div>
                            
                            <div class="js_link_container">
                                <t t-call="claro_bo_op.status_record_list_items"/>
                            </div>
                            
                        </form>
                    </div>
                </li>
            </ul>
        </div>
    </t>

    <t t-name="claro_bo_op.status_record_list_items">
        <t t-if="widget.links_list &amp;&amp; widget.links_list.length > 0">
            <div class="form-group mb-0">
                <t t-foreach="widget.links_list" t-as="link">
                    <div class="col-100">
                        <h4>
                            <a t-att-href="link.url" title="Check Btn" role="button">
                                <t t-esc="link.text"/>
                            </a>
                        </h4>
                        <hr style="border: none; border-bottom: 1px solid gainsboro;"/>
                    </div>
                </t>
            </div>
        </t>
        <t t-else="">
            <div class="text-center text-muted" style="padding: 10px;">
                No hay ventas en proceso.
            </div>
        </t>
    </t>
</templates>