    <record id="oportunidad_form_view_bo" model="ir.ui.view">
      <field name="name">claro_bo_op.oportunidad_form_view_bo</field>
      <field name="model">claro_oportunidades.oportunidad</field>
      <field name="inherit_id" ref="claro_oportunidades.oportunidad_form_view_bo" />
      <field name="arch" type="xml">
        <xpath expr="//notebook" position="before">
          <widget name="web_ribbon" title="ASIGNADO" bg_color="bg-info"
            attrs="{'invisible': [('ribbon_dynamic_title', '!=', 'INICIO')]}" />
          <widget name="web_ribbon" title="EN PROCESO" bg_color="bg-warning"
            attrs="{'invisible': [('ribbon_dynamic_title', '!=', 'INTERMEDIO-SUB'),('ribbon_dynamic_title', '!=', 'INTERMEDIO')]}" />
          <widget name="web_ribbon" title="TERMINADO" bg_color="bg-success"
            attrs="{'invisible': [('ribbon_dynamic_title', '!=', 'FIN')]}" />
          <field name="ribbon_dynamic_title" invisible="1" readonly="1" force_save="1" />
        </xpath>
        <!-- attrs="{'invisible': [('active', '=', True),('rechazado', '=', False)]}"  -->
        <xpath expr="//field[@name='asesor']" position="after">
          <field name="bo_assigned_user" readonly="1" force_save="1" />

          <button name="set_assigned_bo_by_self" string="Asignarme"
            type="object" class="btn-primary"
            attrs="{'invisible':[('bo_assigned_user','!=',False)]}"
            confirm="Asignarme la gestion de la venta"
            groups="claro_oportunidades.group_claro_oportunidades_bo" />
        </xpath>

        <xpath expr="//field[@name='supervisor']" position="after">
          <field name="bo_assigned_last_rec" readonly="1" force_save="1" />
        </xpath>

        <xpath expr="//button[@name='set_permitir_edicion']" position="before">
          <button name="get_next_status_bo_assigned"
            string="Siguiente" type="object"
            class="btn-danger" icon="fa-arrow-right"
            attrs="{'invisible': [('ribbon_dynamic_title', '=', 'FIN')]}" />
        </xpath>

        <!-- op_contratos-->
        <xpath expr="//page[@name='cl_cont_contratos']" position="after">

          <page string="Seguimiento BO" name="claro_bo_op_status"
            groups="claro_oportunidades.group_claro_oportunidades_bo">
            <group>
              <div class="oe_button_box" name="button_box"
                groups="claro_oportunidades.group_claro_oportunidades_bo">

                <button name="get_next_status_bo_assigned"
                  string="Siguiente" type="object"
                  class="btn-danger" icon="fa-arrow-right"
                  attrs="{'invisible': [('ribbon_dynamic_title', '=', 'FIN')]}" />
              </div>
            </group>

            <field name="status_op_rec_ids" mode="tree">
              <tree editable="top" create="0">
                <field name="bo_status_op" readonly="1" force_save="1" />
                <field name="start_date" readonly="1" force_save="1" />
                <field name="end_date" readonly="1" force_save="1" />
                <field name="rq_respaldo" readonly="1" force_save="1" />
                <field name="respaldo_ids" widget="many2many_binary" />

              </tree>
            </field>


          </page>

        </xpath>
      </field>
    </record>


    <record id="claro_bo_op_settings_view__oportunidad" model="ir.ui.view">
      <field name="name">claro_bo_op.res.config.settings.form</field>
      <field name="model">res.config.settings</field>
      <field name="inherit_id" ref="base.res_config_settings_view_form" />
      <field name="arch" type="xml">
        <xpath expr="//div[@id='claro_oportunidades_generar_contratos_text_block']" position="after">
          <h2>BO ASSIGNED NOTIFY URL HOST</h2>

          <div class="row mt16 o_settings_container"
            id="claro_bo_op_bo_assigned_text_block">
            <div class="col-12 col-lg-6 o_setting_box">
              <label for="bo_assigned_host" />
              <field name="bo_assigned_host"
              />
              <div class="text-muted">
                URL PARA CHAT DE NOTIFICACION (ENLACE DIRECTO A VENTA)
              </div>
            </div>
          </div>
        </xpath>
      </field>
    </record>

    <record model="ir.ui.view" id="claro_bo_op.status_op_rec_form_view">
      <field name="name">claro_bo_op.status_op_rec.view.form</field>
      <field name="model">claro_bo_op.status_op_rec</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="bo_status_op"
                options="{ &quot;no_open&quot;: True, &quot;no_create&quot;: True}" />
              <field name="start_date" readonly="1" force_save="1" />
              <field name="end_date" readonly="1" force_save="1" />
              <field name="oportunidad" readonly="1" force_save="1" />
              <field name="rq_respaldo" readonly="1" force_save="1" />
            </group>
          </sheet>
          <footer>
            <button name="action_save_and_close" string="Guardar" type="object" class="btn-primary"
              data-hotkey="q" />
            <button string="Cancelar" class="btn-secondary" special="cancel" data-hotkey="z" />
          </footer>
        </form>
      </field>
    </record>

  </data>
