<odoo>
  <data>

    <record id="oportunidad_form_view_vn" model="ir.ui.view">
      <field name="name">claro_bo_op.oportunidad_form_view_cn</field>
      <field name="model">claro_oportunidades.oportunidad</field>
      <field name="inherit_id" ref="claro_oportunidades.oportunidad_form_view_vn" />
      <field name="arch" type="xml">
        <xpath expr="//field[@name='supervisor']" position="after">
          <field name="bo_assigned_user" readonly="1" force_save="1" />
        </xpath>

        <xpath expr="//notebook" position="before">
          <group>
            <div class="oe_button_box" name="button_box">
              <button name="set_need_assigned"
                string="Solicitar Gestion" type="object"
                class="btn-danger" icon="fa-user-plus"
                 attrs="{'invisible': [('bo_assigned_await', '=', True),('bo_assigned_user', '!=', False)]}"
                />

                  <field name="bo_assigned_await" invisible="1" />
                  <field name="bo_assigned_user" invisible="1" />
            </div>

          </group>

        </xpath>
      </field>
    </record>

