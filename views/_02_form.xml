       <button name="set_assigned_bo_by_self" string="Asignarme" 
       type="object" class="btn-primary" 
        attrs="{'invisible':[('bo_assigned_user','!=',False)]}" 
       confirm="Asignarme la gestion de la venta" 
       groups="claro_oportunidades.group_claro_oportunidades_bo"/>
    </xpath>
  </field>
