        <record id="claro_bo_op_settings_view__oportunidad" model="ir.ui.view">
            <field name="name">claro_bo_op.res.config.settings.form</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form" />
            <field name="arch" type="xml">
               <xpath expr="//div[@id='claro_oportunidades_generar_contratos_text_block']" position="after">
                       <h2>BO ASSIGNED NOTIFY URL HOST</h2>

                        <div class="row mt16 o_settings_container"
                            id="claro_bo_op_bo_assigned_text_block">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <label for="bo_assigned_host" />
                                <field name="bo_assigned_host"
                                     />
                                <div class="text-muted">
                                   URL PARA CHAT DE NOTIFICACION (ENLACE DIRECTO A VENTA)
                                </div>
                            </div>
                        </div>
                </xpath>
            </field>
        </record>

